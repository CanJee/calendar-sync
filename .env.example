# ─── Google Calendar (iCal) ──────────────────────────────────────────────────
# Get these from: Google Calendar → Settings → [calendar name] → "Secret address in iCal format"
GOOGLE_CALENDAR_WORK_ICAL_URL=https://calendar.google.com/calendar/ical/YOUR_WORK_EMAIL%40DOMAIN.com/private-XXXX/basic.ics
GOOGLE_CALENDAR_PERSONAL_ICAL_URL=https://calendar.google.com/calendar/ical/YOUR_PERSONAL_EMAIL%40DOMAIN.com/private-XXXX/basic.ics

# ─── Partner's Calendars ─────────────────────────────────────────────────────
# Work shift schedule (iCal/webcal link from scheduling system)
LAILS_SUNNYBROOK_ICAL_URL=webcal://YOUR_SHIFT_SCHEDULE_ICAL_URL

# Partner's personal Google Calendar — secret iCal address
# In Google Calendar: Settings → [calendar] → "Secret address in iCal format"
LAILS_PERSONAL_ICAL_URL=https://calendar.google.com/calendar/ical/PARTNER_EMAIL%40DOMAIN.com/private-XXXX/basic.ics

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Sign up at resend.com — free tier is plenty (100 emails/day)
# Add and verify a domain, or use the default resend.dev sandbox for testing
RESEND_API_KEY=re_...
RESEND_DOMAIN=yourdomain.com   # domain you verified in Resend (or omit to use resend.dev sandbox)

# Your details (used in email templates)
OWNER_EMAIL=you@example.com
OWNER_NAME=Hasan
PARTNER_EMAIL=partner@example.com
PARTNER_NAME=Lails

# Public URL of the deployed app (used for approve/reject links in emails)
APP_URL=https://your-app.vercel.app

# ─── App Config ──────────────────────────────────────────────────────────────
# A random secret for accessing the admin view at /admin
ADMIN_SECRET_KEY=choose-a-long-random-string-here
